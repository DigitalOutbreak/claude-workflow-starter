---
const steps = [
  {
    n: '01',
    title: 'Install globally',
    body: 'Picks every agent you have installed — Claude Code, Codex, Cursor, Gemini, and ~12 more. Space toggles, enter confirms.',
    code: 'npx skills add DigitalOutbreak/workflow -g',
  },
  {
    n: '02',
    title: 'Bootstrap a project',
    body: 'From any project directory, in your agent. Runs the 10-stage guided flow — pre-flight, scaffold (optional), discovery interview, roadmap, template fill, first feature recommendation.',
    code: '/workflow-init',
  },
  {
    n: '03',
    title: 'Ship a feature',
    body: 'Spec it, load the spec into context, cut a branch, implement, complete. Each command is a single, observable step.',
    code: '/feature spec   →   /feature load   →   /feature start',
  },
];

const alt = [
  {
    label: 'Skip the picker',
    code: 'npx skills add DigitalOutbreak/workflow -g -y',
    body: 'One-shot install for every detected agent.',
  },
  {
    label: 'Install project-local',
    code: 'npx skills add DigitalOutbreak/workflow',
    body: 'Drops into .agents/skills/ — checked into version control with the project.',
  },
  {
    label: 'Backwards-compat CLI',
    code: 'npx @digitaloutbreak/workflow',
    body: 'Our own CLI · Claude / Codex / Gemini only · use --all to skip the prompt.',
  },
];
---

<section class="relative">
  <div class="container-page py-24 md:py-32 border-t border-[var(--color-hairline)]">
    <div id="quickstart" class="max-w-2xl scroll-mt-20">
      <span class="eyebrow">Quickstart</span>
      <h2
        class="mt-3 text-[var(--color-ink)] text-balance font-semibold"
        style="font-size: clamp(2rem, 4.5vw, 3.25rem); line-height: 1.1; letter-spacing: -0.025em;"
      >
        How to get started.
      </h2>
    </div>

    <ol class="mt-14 space-y-5">
      {steps.map((s) => (
        <li class="grid md:grid-cols-[3rem_1fr] gap-5 items-start">
          <div class="h-12 w-12 rounded-[12px] bg-[var(--color-surface-1)] border border-[var(--color-hairline)] grid place-items-center font-mono text-[14px] text-[var(--color-ink)]">
            {s.n}
          </div>
          <div class="card p-6">
            <h3 class="text-[var(--color-ink)] font-semibold" style="font-size: 18px; line-height: 1.3; letter-spacing: -0.015em;">{s.title}</h3>
            <p class="mt-2 text-[14px] text-[var(--color-ink-muted)] leading-[1.55]">{s.body}</p>
            <button
              type="button"
              data-copy={s.code}
              class="mt-5 group w-full flex items-center gap-3 rounded-[8px] bg-[var(--color-surface-2)] border border-[var(--color-hairline)] hover:border-[var(--color-hairline-strong)] px-4 py-3 text-left transition-colors"
            >
              <span class="text-[var(--color-ink-subtle)] font-mono text-[13px] select-none">$</span>
              <code class="font-mono text-[13px] text-[var(--color-ink)] flex-1 overflow-x-auto whitespace-nowrap">{s.code}</code>
              <span data-copy-icon class="text-[var(--color-ink-tertiary)] group-hover:text-[var(--color-ink-subtle)] transition-colors shrink-0">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="9" y="9" width="13" height="13" rx="2" />
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                </svg>
              </span>
              <span data-copied-icon class="shrink-0">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </span>
            </button>
          </div>
        </li>
      ))}
    </ol>

    <div class="mt-16">
      <h3 class="text-[14px] font-semibold text-[var(--color-ink-muted)] tracking-tight">Other install paths</h3>
      <div class="mt-4 grid md:grid-cols-3 gap-4">
        {alt.map((a) => (
          <div class="card p-5">
            <div class="text-[12px] text-[var(--color-ink-tertiary)] font-mono uppercase tracking-wider">{a.label}</div>
            <button
              type="button"
              data-copy={a.code}
              class="mt-3 w-full text-left font-mono text-[12px] text-[var(--color-ink)] bg-[var(--color-surface-2)] border border-[var(--color-hairline)] rounded-md px-3 py-2 hover:border-[var(--color-hairline-strong)] transition-colors overflow-x-auto whitespace-nowrap"
            >
              <span class="text-[var(--color-ink-subtle)] select-none">$ </span>{a.code}
            </button>
            <p class="mt-3 text-[12px] text-[var(--color-ink-muted)] leading-[1.55]">{a.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

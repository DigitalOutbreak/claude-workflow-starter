---
const tree = [
  { depth: 0, name: 'CLAUDE.md',                kind: 'root',     note: 'Claude Code brief · @-imports the context docs' },
  { depth: 0, name: 'AGENTS.md',                kind: 'root',     note: 'Universal pointer for any AI agent' },
  { depth: 0, name: 'GEMINI.md',                kind: 'root',     note: 'Gemini Code Assist brief' },
  { depth: 0, name: 'docs/',                    kind: 'dir' },
  { depth: 1, name: 'context/',                 kind: 'dir',      note: 'auto-imported every session' },
  { depth: 2, name: 'thesis.md',                kind: 'template', note: 'Strategic memo — why this product exists' },
  { depth: 2, name: 'project-overview.md',      kind: 'template', note: 'Scope, stack, surfaces, decisions log' },
  { depth: 2, name: 'coding-standards.md',      kind: 'starter',  note: 'Defaults — rewritten by /workflow-init' },
  { depth: 2, name: 'ai-interaction.md',        kind: 'literal',  note: 'How the agent communicates' },
  { depth: 2, name: 'current-feature.md',       kind: 'literal',  note: 'Active feature · updated by /feature' },
  { depth: 2, name: 'roadmap.md',               kind: 'template', note: 'Now / Next / Later phases' },
  { depth: 2, name: 'backlog.md',               kind: 'literal',  note: 'Deferred items, categorised' },
  { depth: 2, name: 'features/',                kind: 'dir',      note: 'per-feature specs land here' },
  { depth: 1, name: 'specs/',                   kind: 'dir' },
  { depth: 2, name: 'project-spec.md',          kind: 'template', note: 'Source-of-truth spec · read on demand' },
  { depth: 0, name: '.claude/',                 kind: 'dir' },
  { depth: 1, name: 'agents/',                  kind: 'dir' },
  { depth: 2, name: 'code-scanner.md',          kind: 'literal',  note: 'Quality · security · perf review agent' },
  { depth: 1, name: 'skills/',                  kind: 'dir' },
  { depth: 2, name: 'feature/',                 kind: 'literal',  note: '/feature spec → load → start → review → complete' },
  { depth: 2, name: 'cleanup/',                 kind: 'literal',  note: '/cleanup housekeeping scan' },
];

const kindLabel: Record<string, string> = {
  root: 'ROOT',
  dir: 'DIR',
  template: 'TMPL',
  starter: 'START',
  literal: 'LIT',
};
---

<section class="relative">
  <div class="container-page py-24 md:py-32 border-t border-[var(--color-hairline)]">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
      <div id="install" class="lg:col-span-5 lg:sticky lg:top-24 scroll-mt-20">
        <span class="eyebrow">What gets installed</span>
        <h2
          class="mt-3 text-[var(--color-ink)] text-balance font-semibold"
          style="font-size: clamp(2rem, 4.5vw, 3.25rem); line-height: 1.1; letter-spacing: -0.025em;"
        >
          Just 21 files in your repo.
        </h2>
        <p class="mt-5 text-[var(--color-ink-muted)] text-pretty" style="font-size: 17px; line-height: 1.55; letter-spacing: -0.005em;">
          Everything lands inside your project — no global state, no daemon, no runtime. You can
          delete it with <code class="font-mono text-[0.92em] text-[var(--color-ink)] bg-[var(--color-surface-2)] px-1.5 py-0.5 rounded">rm -rf .claude docs/context docs/specs</code>
          and you're back to a vanilla repo.
        </p>

        <dl class="mt-7 space-y-3 text-[14px]">
          <div class="flex items-start gap-3">
            <span class="font-mono text-[11px] px-1.5 py-0.5 rounded-md shrink-0 mt-0.5 bg-[var(--color-surface-2)] text-[var(--color-accent)] border border-[var(--color-hairline)]">ROOT</span>
            <dd class="text-[var(--color-ink-muted)]">Top-level brief that points the agent at the context docs.</dd>
          </div>
          <div class="flex items-start gap-3">
            <span class="font-mono text-[11px] px-1.5 py-0.5 rounded-md shrink-0 mt-0.5 bg-[var(--color-surface-2)] text-[var(--color-accent)] border border-[var(--color-hairline)]">TMPL</span>
            <dd class="text-[var(--color-ink-muted)]">Has &#123;&#123;Placeholders&#125;&#125; — filled in by /workflow-init.</dd>
          </div>
          <div class="flex items-start gap-3">
            <span class="font-mono text-[11px] px-1.5 py-0.5 rounded-md shrink-0 mt-0.5 bg-[var(--color-surface-2)] text-[var(--color-accent)] border border-[var(--color-hairline)]">START</span>
            <dd class="text-[var(--color-ink-muted)]">Sensible defaults for your stack — edit as you go.</dd>
          </div>
          <div class="flex items-start gap-3">
            <span class="font-mono text-[11px] px-1.5 py-0.5 rounded-md shrink-0 mt-0.5 bg-[var(--color-surface-2)] text-[var(--color-accent)] border border-[var(--color-hairline)]">LIT</span>
            <dd class="text-[var(--color-ink-muted)]">Copy as-is. Don't modify unless you really mean to.</dd>
          </div>
        </dl>
      </div>

      <div class="lg:col-span-7">
        <div class="product-frame">
          <div class="product-frame-header">
            <span class="font-mono text-[11px] text-[var(--color-ink-tertiary)]">project-root/</span>
            <span class="font-mono text-[11px] text-[var(--color-ink-tertiary)]">21 files</span>
          </div>
          <ul class="font-mono text-[13px] divide-y divide-[var(--color-hairline)]">
            {tree.map((node) => (
              <li class="grid grid-cols-[1fr_auto] items-center gap-3 px-4 py-2 hover:bg-[var(--color-surface-2)] transition-colors">
                <div class="flex items-center gap-2" style={`padding-left: ${node.depth * 14}px;`}>
                  {node.depth > 0 && <span class="text-[var(--color-ink-tertiary)]">└</span>}
                  {node.kind === 'dir' ? (
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-ink-tertiary)]">
                      <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                    </svg>
                  ) : (
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-ink-tertiary)]">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6"/>
                    </svg>
                  )}
                  <span class={node.kind === 'dir' ? 'text-[var(--color-ink)]' : 'text-[var(--color-ink-muted)]'}>{node.name}</span>
                  {node.note && (
                    <span class="hidden lg:inline ml-3 text-[var(--color-ink-tertiary)] truncate">— {node.note}</span>
                  )}
                </div>
                <span class={`text-[10px] tracking-wider shrink-0 ${node.kind === 'dir' ? 'text-[var(--color-ink-tertiary)]' : 'text-[var(--color-accent)]'}`}>
                  {kindLabel[node.kind]}
                </span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

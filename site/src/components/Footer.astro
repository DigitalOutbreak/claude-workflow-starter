---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-hairline)]">
  <div class="container-page py-10">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div class="flex items-baseline gap-1.5">
        <span class="font-mono text-[13px] text-[var(--color-ink-muted)]">@digitaloutbreak</span>
        <span class="font-mono text-[13px] text-[var(--color-accent)] select-none">/</span>
        <span class="font-mono text-[13px] text-[var(--color-ink-muted)]">workflow</span>
      </div>

      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-[14px] text-[var(--color-ink-muted)]">
        <a href="https://github.com/DigitalOutbreak/workflow" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-ink)] transition-colors">GitHub</a>
        <a href="https://www.npmjs.com/package/@digitaloutbreak/workflow" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-ink)] transition-colors">npm</a>
        <a href="https://www.skills.sh" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-ink)] transition-colors">open agent skills</a>
        <a href="https://github.com/DigitalOutbreak/workflow/issues" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-ink)] transition-colors">Issues</a>
      </div>

      <p class="font-mono text-[12px] text-[var(--color-ink-tertiary)]">MIT · © {year} DigitalOutbreak</p>
    </div>
  </div>
</footer>

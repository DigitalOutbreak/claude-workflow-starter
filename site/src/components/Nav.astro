---
const version = 'v0.15.8';
const pathname = Astro.url.pathname;
const onDocs = pathname.startsWith('/docs');
const onBlog = pathname.startsWith('/blog');
const offHome = onDocs || onBlog;

const links = [
  { href: offHome ? '/#features' : '#features', label: 'Features' },
  { href: offHome ? '/#workflow' : '#workflow', label: 'Workflow' },
  { href: offHome ? '/#install' : '#install', label: 'Install' },
  { href: '/docs', label: 'Docs', isDocs: true },
  { href: '/blog', label: 'Blog', isBlog: true },
];
---

<header class="sticky top-0 z-40 bg-[color:var(--color-canvas)]/85 backdrop-blur-md border-b border-[var(--color-hairline)]">
  <div class="container-page flex h-14 items-center justify-between">
    <a href="/" class="flex items-baseline gap-1.5 group">
      <span class="text-[13px] text-[var(--color-ink-tertiary)]">digitaloutbreak</span>
      <span class="text-[14px] text-[var(--color-accent)] select-none">/</span>
      <span class="text-[14px] font-semibold tracking-tight text-[var(--color-ink)]">workflow</span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-[14px] text-[var(--color-ink-subtle)]">
      {links.map((l) => {
        const active =
          ((l as any).isDocs && onDocs) || ((l as any).isBlog && onBlog);
        return (
          <a
            href={l.href}
            class={active
              ? 'text-[var(--color-ink)] transition-colors'
              : 'hover:text-[var(--color-ink)] transition-colors'}
          >
            {l.label}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-3">
      <span class="text-[12px] text-[var(--color-ink-tertiary)] hidden sm:inline">{version}</span>
      <a
        href="https://github.com/DigitalOutbreak/workflow"
        target="_blank"
        rel="noopener noreferrer"
        class="button-secondary !py-1.5 !px-3 !text-[13px]"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.56C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z"/>
        </svg>
        <span>GitHub</span>
      </a>
    </div>
  </div>
</header>

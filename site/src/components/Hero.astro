---
const installCmd = 'npx skills add DigitalOutbreak/workflow -g';
---

<section class="relative overflow-hidden">
  <div class="hero-blob" aria-hidden="true"></div>
  <div class="hero-blob-2" aria-hidden="true"></div>
  <div class="hero-texture" aria-hidden="true"></div>
  <div class="hero-floor" aria-hidden="true"></div>
  <div class="container-page pt-20 md:pt-28 pb-20 md:pb-28 relative">
    <!-- Status badge -->
    <div class="flex justify-center animate-fade-up">
      <span class="status-badge">
        <span class="status-dot"></span>
        <span>v0.15.8 · Drop-in AI coding workflow</span>
      </span>
    </div>

    <!-- Headline -->
    <h1
      class="mt-7 text-center text-balance font-display font-semibold text-[var(--color-ink)] animate-fade-up"
      style="font-size: clamp(2.75rem, 7.5vw, 4.75rem); line-height: 1.02; letter-spacing: -0.035em; animation-delay: 60ms;"
    >
      A workflow scaffold for AI coding agents.
    </h1>

    <p
      class="mt-6 max-w-2xl mx-auto text-center text-pretty text-[var(--color-ink-muted)] animate-fade-up"
      style="font-size: 18px; line-height: 1.55; letter-spacing: -0.005em; animation-delay: 120ms;"
    >
      One install gives every project
      a <span class="font-mono text-[var(--color-ink)] text-[0.94em]">/workflow-init</span> bootstrap,
      a <span class="font-mono text-[var(--color-ink)] text-[0.94em]">/feature</span> lifecycle,
      a <span class="font-mono text-[var(--color-ink)] text-[0.94em]">/cleanup</span> skill, and
      a <span class="font-mono text-[var(--color-ink)] text-[0.94em]">code-scanner</span> agent —
      across Claude Code, Codex, Cursor, Gemini, and ~12 more.
    </p>

    <!-- CTAs -->
    <div class="mt-9 flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3 animate-fade-up" style="animation-delay: 180ms;">
      <button type="button" data-copy={installCmd} class="command-pill group" aria-label="Copy install command">
        <span class="prompt">$</span>
        <code class="font-mono flex-1 overflow-x-auto whitespace-nowrap">{installCmd}</code>
        <span data-copy-icon class="copy-icon inline-flex items-center justify-center h-6 w-6">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" />
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
          </svg>
        </span>
        <span data-copied-icon class="inline-flex items-center justify-center h-6 w-6">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </span>
      </button>

      <a href="#quickstart" class="button-primary">
        Quick start
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </div>

    <!-- Meta -->
    <div class="mt-6 flex justify-center gap-x-5 gap-y-2 flex-wrap text-[12px] text-[var(--color-ink-tertiary)] animate-fade-up" style="animation-delay: 240ms;">
      <span class="flex items-center gap-1.5">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        21 files installed
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Web · Backend · Mobile · CLI · Library
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        MIT licensed
      </span>
    </div>

    <!-- Product-screenshot equivalent (terminal preview) -->
    <div class="mt-14 md:mt-20 mx-auto max-w-4xl animate-fade-up" style="animation-delay: 300ms;">
      <div class="product-frame">
        <div class="product-frame-header">
          <div class="flex items-center gap-1.5">
            <span class="h-2.5 w-2.5 rounded-full bg-[#3a3b3e]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#3a3b3e]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#3a3b3e]"></span>
          </div>
          <span class="font-mono text-[11px] text-[var(--color-ink-tertiary)]">~/projects/my-app — claude code</span>
          <span class="w-12"></span>
        </div>

        <div class="px-5 py-5 font-mono text-[13px] leading-[1.7]">
          <div>
            <span class="text-[var(--color-accent)]">›</span>
            <span class="text-[var(--color-ink-muted)]"> /workflow-init</span>
          </div>
          <div class="mt-3 text-[var(--color-ink-subtle)]">
            <span class="text-[var(--color-ink)]">Stage 02 · Pre-flight</span>
            <div class="ml-3 mt-1 text-[var(--color-ink-tertiary)]">Project type? <span class="text-[var(--color-ink-muted)]">Web</span> · Scaffold? <span class="text-[var(--color-ink-muted)]">Next.js + shadcn</span></div>
          </div>
          <div class="mt-3 text-[var(--color-ink-subtle)]">
            <span class="text-[var(--color-ink)]">Stage 03 · Installing workflow files</span>
            <div class="ml-3 mt-1 text-[var(--color-ink-tertiary)]">
              <span class="text-[var(--color-success)]">✓</span> CLAUDE.md · AGENTS.md · GEMINI.md<br/>
              <span class="text-[var(--color-success)]">✓</span> docs/context/ · docs/specs/<br/>
              <span class="text-[var(--color-success)]">✓</span> .claude/skills/feature · .claude/skills/cleanup<br/>
              <span class="text-[var(--color-success)]">✓</span> .claude/agents/code-scanner.md
            </div>
          </div>
          <div class="mt-3 text-[var(--color-ink-subtle)]">
            <span class="text-[var(--color-ink)]">Stage 04 · Discovery interview</span>
            <div class="ml-3 mt-1 text-[var(--color-ink-tertiary)]">Identity · Stack · Strategy · Surfaces</div>
          </div>
          <div class="mt-4 pt-3 border-t border-[var(--color-hairline)]">
            <span class="text-[var(--color-accent)]">›</span>
            <span class="text-[var(--color-ink)]"> Ready. Try </span>
            <span class="font-mono text-[var(--color-ink)] bg-[var(--color-surface-2)] px-1.5 py-0.5 rounded">/feature spec</span>
            <span class="text-[var(--color-ink)]"> to ship the first one.</span>
            <span class="caret"></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

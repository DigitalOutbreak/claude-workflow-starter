---
const agents = [
  { name: 'Claude Code',         invoke: '/workflow-init',    confirmed: true },
  { name: 'Codex',               invoke: '$workflow-init',    confirmed: true },
  { name: 'Gemini CLI',          invoke: '/workflow-init',    confirmed: true },
  { name: 'Cursor',              invoke: 'reads AGENTS.md',   confirmed: false },
  { name: 'Cline',               invoke: 'reads AGENTS.md',   confirmed: false },
  { name: 'Aider',               invoke: 'reads AGENTS.md',   confirmed: false },
  { name: 'Continue',            invoke: 'reads AGENTS.md',   confirmed: false },
  { name: 'Windsurf',            invoke: 'reads AGENTS.md',   confirmed: false },
  { name: 'Copilot',             invoke: 'reads AGENTS.md',   confirmed: false },
  { name: 'OpenCode',            invoke: 'reads AGENTS.md',   confirmed: false },
  { name: 'Gemini Code Assist',  invoke: 'reads GEMINI.md',   confirmed: false },
  { name: '+ more',              invoke: 'open agent skills', confirmed: false },
];
---

<section class="relative">
  <div class="container-page py-24 md:py-32 border-t border-[var(--color-hairline)]">
    <div class="max-w-2xl">
      <span class="eyebrow">Compatibility</span>
      <h2
        class="mt-3 text-[var(--color-ink)] text-balance font-semibold"
        style="font-size: clamp(2rem, 4.5vw, 3.25rem); line-height: 1.1; letter-spacing: -0.025em;"
      >
        Works with whatever agent you're already using.
      </h2>
      <p class="mt-5 text-[var(--color-ink-muted)] text-pretty" style="font-size: 17px; line-height: 1.55; letter-spacing: -0.005em;">
        Three root files ship together — <span class="font-mono text-[var(--color-ink)] text-[0.94em]">CLAUDE.md</span>,
        <span class="font-mono text-[var(--color-ink)] text-[0.94em]">AGENTS.md</span>, and
        <span class="font-mono text-[var(--color-ink)] text-[0.94em]">GEMINI.md</span> — so collaborators on the same
        project can switch tools without losing context.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-px bg-[var(--color-hairline)] border border-[var(--color-hairline)] rounded-[12px] overflow-hidden">
      {agents.map((a) => (
        <div class="bg-[var(--color-surface-1)] p-5 hover:bg-[var(--color-surface-2)] transition-colors">
          <div class="flex items-center gap-2">
            <span class={`h-1.5 w-1.5 rounded-full ${a.confirmed ? 'bg-[var(--color-success)]' : 'bg-[var(--color-ink-tertiary)]'}`}></span>
            <span class="text-[14px] font-semibold tracking-tight text-[var(--color-ink)]">{a.name}</span>
          </div>
          <div class="mt-3 font-mono text-[11px] text-[var(--color-ink-muted)]">{a.invoke}</div>
        </div>
      ))}
    </div>

    <p class="mt-6 text-[12px] text-[var(--color-ink-tertiary)] flex flex-wrap items-center gap-x-4 gap-y-2">
      <span class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-[var(--color-success)]"></span>confirmed slash-command support</span>
      <span class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-[var(--color-ink-tertiary)]"></span>reads AGENTS.md · slash command coming as the format is verified</span>
    </p>
  </div>
</section>
